# ─────────────────────────────────────────────────────────────────────────────
#  ArchLens — Environment Configuration
#
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# sqlite (default, zero configuration) | mysql | postgres
DB_TYPE=sqlite

# SQLite file path. In Docker this is automatically set to /app/data/archlens.db
# DB_PATH=./archlens.db

# MySQL — only needed when DB_TYPE=mysql
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=archlens
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=archlens

# PostgreSQL — only needed when DB_TYPE=postgres
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=archlens
# PG_PASSWORD=your-password
# PG_DATABASE=archlens

# ── AI Provider ───────────────────────────────────────────────────────────────
# Required for: Vendor Analysis, Vendor Resolution, Duplicate Detection, Architecture AI
# Not required for: Connect, Sync, Overview, Fact Sheet Intel, Settings

# Provider: claude | openai | deepseek | gemini
AI_PROVIDER=claude

# Anthropic Claude — https://console.anthropic.com/settings/keys
# AI_API_KEY=sk-ant-api03-...

# OpenAI — https://platform.openai.com/api-keys
# AI_API_KEY=sk-...

# DeepSeek — https://platform.deepseek.com/api_keys
# AI_API_KEY=sk-...

# Google Gemini — https://ai.google.dev/gemini-api/docs/api-key
# AI_API_KEY=...

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Default allows localhost:3000.
# Only needed if running behind a reverse proxy on a custom domain.
# CORS_ORIGINS=https://archlens.yourcompany.com
