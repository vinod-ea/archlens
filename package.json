{
  "name": "archlens",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "dev": "concurrently --names SERVER,CLIENT --prefix-colors yellow,cyan \"node server/index.js\" \"cd client && npm start\"",
    "server": "node server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "start": "NODE_ENV=production node server/index.js",
    "docker:build": "docker build -t archlens:latest .",
    "docker:run": "docker run -p 3000:3000 -v archlens-data:/app/data archlens:latest",
    "lint": "cd client && npx eslint src --ext .js,.jsx --max-warnings 0",
    "test": "cd client && npm test -- --watchAll=false --passWithNoTests"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0"
  },
  "description": "EA Intelligence platform for LeanIX — AI-powered vendor analysis, duplicate detection and architecture insights",
  "keywords": [
    "leanix",
    "enterprise-architecture",
    "ea",
    "vendor-analysis",
    "architecture-intelligence"
  ],
  "license": "MIT",
  "author": "ArchLens Contributors",
  "homepage": "https://github.com/vinod-ea/archlens",
  "repository": {
    "type": "git",
    "url": "https://github.com/vinod-ea/archlens.git"
  },
  "bugs": {
    "url": "https://github.com/vinod-ea/archlens/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
